---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const { title, description = 'ailaugh.ing — When will AI become self-cognizant? Will it make itself laugh? A premier, thought-provoking domain for sale at the intersection of AI, consciousness, and humor.', ogImage } = Astro.props;
const pathname = Astro.url.pathname.endsWith('/') ? Astro.url.pathname : Astro.url.pathname + '/';
const canonicalURL = new URL(pathname, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalURL} />

    <!-- Google Site Verification -->
    <meta name="google-site-verification" content="HT1Nn5uchSz8MHyIEl_IBUmXNtbGi-lAKt0WYDpLfG0" />

    <!-- Preconnect to CDN -->
    <link rel="preconnect" href="https://imagedelivery.net" />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Space+Grotesk:wght@500;600&display=swap" rel="stylesheet" />

    <title>{title}</title>

    <slot name="head" />
  </head>
  <body class="bg-[#0a0a0f] text-white overflow-x-hidden antialiased">
    <!-- Navigation -->
    <nav id="navbar" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 border-b border-white/5 bg-[#0a0a0f]/95 backdrop-blur-[20px]">
      <div class="max-w-6xl mx-auto px-6">
        <div class="flex items-center justify-between h-20">
          <!-- Logo -->
          <div class="flex items-center gap-x-3">
            <div class="w-9 h-9 rounded-2xl bg-gradient-to-br from-[#22f5ff] via-[#a855f7] to-[#22f5ff] p-px">
              <div class="w-full h-full bg-[#0a0a0f] rounded-2xl flex items-center justify-center">
                <span class="text-[#22f5ff] text-xl font-bold tracking-tighter">AI</span>
              </div>
            </div>
            <div>
              <div class="font-display text-2xl font-semibold tracking-tighter">ailaugh.ing</div>
            </div>
          </div>

          <!-- Desktop Navigation -->
          <div class="hidden md:flex items-center gap-x-9 text-sm font-medium">
            <a href="#question" class="nav-link text-white/80 hover:text-white">The Question</a>
            <a href="#why" class="nav-link text-white/80 hover:text-white">Why This Domain</a>
            <a href="#uses" class="nav-link text-white/80 hover:text-white">Potential</a>
            <a href="#pricing" class="nav-link text-white/80 hover:text-white">Pricing</a>
          </div>

          <!-- CTA Buttons -->
          <div class="flex items-center gap-x-3">
            <a href="#inquire"
               class="hidden sm:inline-flex items-center justify-center px-6 py-2.5 text-sm font-semibold rounded-2xl border border-white/20 hover:bg-white/5 transition-colors">
              Inquire
            </a>
            <a href="mailto:sales@desertrich.com?subject=Acquisition%20Inquiry%20-%20ailaugh.ing&body=Hello,%0D%0A%0D%0AI%20am%20interested%20in%20acquiring%20ailaugh.ing.%20Please%20provide%20details%20and%20next%20steps.%0D%0A%0D%0ABest%20regards,"
               class="inline-flex items-center justify-center px-6 py-2.5 text-sm font-semibold rounded-2xl bg-white text-[#0a0a0f] hover:bg-white/90 transition-all active:scale-[0.985]">
              Secure Now
            </a>

            <!-- Mobile Menu Button -->
            <button id="mobile-menu-btn"
                    class="md:hidden w-10 h-10 flex items-center justify-center text-white/70 hover:text-white transition-colors"
                    aria-label="Toggle menu">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
              </svg>
            </button>
          </div>
        </div>
      </div>
    </nav>

    <!-- Mobile Menu -->
    <div id="mobile-menu" class="hidden md:hidden fixed inset-0 z-40 bg-[#0a0a0f] pt-20">
      <div class="px-6 py-8 flex flex-col gap-y-6 text-lg font-medium">
        <a href="#question" class="mobile-nav-link py-2">The Question</a>
        <a href="#why" class="mobile-nav-link py-2">Why This Domain</a>
        <a href="#uses" class="mobile-nav-link py-2">Potential</a>
        <a href="#pricing" class="mobile-nav-link py-2">Pricing</a>
        <div class="pt-4 border-t border-white/10">
          <a href="mailto:sales@desertrich.com?subject=Acquisition%20Inquiry%20-%20ailaugh.ing"
             class="block w-full text-center py-3.5 rounded-2xl bg-white text-[#0a0a0f] font-semibold">Secure This Domain</a>
        </div>
      </div>
    </div>

    <main>
      <slot />
    </main>

    <!-- Footer -->
    <footer class="border-t border-white/10">
      <div class="max-w-6xl mx-auto px-6 py-10">
        <!-- Domain Acquisition CTA -->
        <div class="bg-gradient-to-b from-white/[0.03] to-white/[0.06] rounded-2xl p-8 md:p-10 mb-8 text-center border border-white/10">
          <div class="inline-flex items-center gap-x-2 px-4 py-1.5 rounded-full border border-white/10 bg-white/5 mb-5">
            <div class="w-1.5 h-1.5 bg-[#22f5ff] rounded-full animate-pulse"></div>
            <span class="text-xs font-semibold tracking-[1.5px] text-white/80">PREMIUM .ING DOMAIN AVAILABLE</span>
          </div>
          <h3 class="text-2xl md:text-3xl font-bold text-white mb-3 font-display tracking-tight">
            Acquire ailaugh.ing
          </h3>
          <p class="text-white/60 max-w-lg mx-auto mb-8 leading-relaxed">
            The domain that asks the question the rest of the internet is afraid to.
            A premium, memorable .ing domain at the intersection of AI consciousness and humor —
            ready for platforms, communities, and visionaries exploring the lighter side of machine intelligence.
          </p>
          <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
            <a
              href="mailto:sales@desertrich.com?subject=Acquisition%20Inquiry%20-%20ailaugh.ing&body=Hello,%0D%0A%0D%0AI%20am%20interested%20in%20acquiring%20ailaugh.ing.%20Please%20provide%20details%20and%20next%20steps.%0D%0A%0D%0ABest%20regards,"
              class="inline-flex items-center justify-center gap-x-2 px-8 py-3 bg-gradient-to-r from-[#22f5ff] to-[#a855f7] text-[#0a0a0f] font-semibold rounded-xl transition-all hover:brightness-105 active:scale-[0.985] shadow-lg shadow-[#22f5ff]/20"
            >
              <span>Inquire: sales@desertrich.com</span>
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M14 5l7 7-7 7M3 12h18" />
              </svg>
            </a>
            <button
              id="copyEmailBtn"
              class="inline-flex items-center justify-center gap-x-2 px-6 py-3 border border-white/20 hover:bg-white/5 text-white/80 font-medium rounded-xl transition-all text-sm"
              onclick="copyEmail()"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
              </svg>
              <span>Copy Email</span>
            </button>
          </div>
          <p class="mt-5 text-xs text-white/40">
            Serious inquiries only. Full ownership transfer via secure escrow (Escrow.com).
          </p>
        </div>

        <!-- Bottom: Disclaimer + Info -->
        <div class="border-t border-white/10 pt-8">
          <p class="text-xs text-white/40 mb-6 leading-relaxed max-w-3xl">
            <strong class="text-white/50">Disclaimer:</strong> This website is for demonstration and informational purposes only. It does not constitute an offer of services,
            a commitment to deploy, or a guarantee of outcomes. All statistics, projections, and references to specific
            technologies are based on publicly available information as of June 2026 and are subject to change.
          </p>
          <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-y-3 text-xs text-white/40">
            <div>
              <p>&copy; 2026 ailaugh.ing &mdash; When Will AI Learn to Laugh?</p>
            </div>
            <div class="flex items-center gap-x-4">
              <span>One-time acquisition</span>
              <span class="hidden md:inline">&bull;</span>
              <span>Full ownership transfer</span>
              <span class="hidden md:inline">&bull;</span>
              <span>Premium .ing TLD</span>
            </div>
          </div>
        </div>
      </div>
    </footer>

    <script>
      function copyEmail() {
        const email = 'sales@desertrich.com';
        navigator.clipboard.writeText(email).then(() => {
          const btn = document.getElementById('copyEmailBtn');
          if (btn) {
            const original = btn.innerHTML;
            btn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" /></svg><span class="text-emerald-400">Copied to clipboard!</span>';
            setTimeout(() => {
              btn.innerHTML = original;
            }, 2200);
          }
        }).catch(() => {
          window.location.href = 'mailto:' + email;
        });
      }

      function toggleMobileMenu() {
        const menu = document.getElementById('mobile-menu');
        const btn = document.getElementById('mobile-menu-btn');
        if (!menu || !btn) return;

        const isHidden = menu.classList.contains('hidden');
        if (isHidden) {
          menu.classList.remove('hidden');
          const icon = btn.querySelector('svg');
          if (icon) {
            icon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6h12v12" />';
          }
        } else {
          menu.classList.add('hidden');
          const icon = btn.querySelector('svg');
          if (icon) {
            icon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />';
          }
        }
      }

      // Attach mobile menu toggle
      document.addEventListener('DOMContentLoaded', () => {
        const btn = document.getElementById('mobile-menu-btn');
        if (btn) {
          btn.addEventListener('click', toggleMobileMenu);
        }

        // Close mobile menu on link click
        document.querySelectorAll('.mobile-nav-link').forEach(link => {
          link.addEventListener('click', () => {
            const menu = document.getElementById('mobile-menu');
            if (menu) menu.classList.add('hidden');
            const btn = document.getElementById('mobile-menu-btn');
            if (btn) {
              const icon = btn.querySelector('svg');
              if (icon) {
                icon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />';
              }
            }
          });
        });

        // Keyboard: ESC closes mobile menu
        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape') {
            const menu = document.getElementById('mobile-menu');
            if (menu && !menu.classList.contains('hidden')) {
              menu.classList.add('hidden');
            }
          }
        });
      });
    </script>
  </body>
</html>
